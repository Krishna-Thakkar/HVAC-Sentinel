# HVAC Sentinel — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# API Keys (Phase 4 — AI Features)
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here  # Alternative to OpenAI

# Dataset path (relative to backend/)
DATASET_PATH=../datasets/raw/hvac_sensor_data.csv

# Server configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:19000,http://localhost:19006,exp://localhost:19000
